{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"],
            "@/app/*": ["app/*"],
            "@/assets/*": ["assets/*"],
            "@/components/*": ["components/*"],
            "@/constants/*": ["constants/*"],
            "@/hooks/*": ["hooks/*"],
            "@/lib/*": ["lib/*"],
            "@/utils/*": ["utils/*"],
            "@/services/*": ["services/*"]
        }
    }
}
